default_platform(:ios)

require "base64"
require "json"

# ─────────────────────────────────────────────────────────────────────────────
# Constants - update these to match your project
# ─────────────────────────────────────────────────────────────────────────────

APP_IDENTIFIER = "com.matsimpson.llmchat"   # ← change to your bundle ID
SCHEME         = "LLMChat"
XCODEPROJ      = "../LLMChat.xcodeproj"
TEAM_ID        = ENV["APPLE_TEAM_ID"]       # set in GitHub Secrets

# ─────────────────────────────────────────────────────────────────────────────
# Shared helpers
# ─────────────────────────────────────────────────────────────────────────────

def parse_asc_payload(payload, key_id, issuer_id)
  return nil if payload.nil? || payload.to_s.strip.empty?

  payload = payload.to_s.strip.gsub("\\n", "\n")
  payload = payload[1..-2] if payload.start_with?("\"") && payload.end_with?("\"")

  if payload.match?(/-----BEGIN (EC )?PRIVATE KEY-----/)
    return [key_id, issuer_id, payload]
  end

  if payload.start_with?("{")
    api_key_json = JSON.parse(payload)
    json_key_id = api_key_json["key_id"] || key_id
    json_issuer_id = api_key_json["issuer_id"] || issuer_id
    json_key = api_key_json["key"] || api_key_json["key_content"] || api_key_json["private_key"]
    parsed_json_key = parse_asc_payload(json_key, json_key_id, json_issuer_id) if json_key
    return parsed_json_key if parsed_json_key
    return [json_key_id, json_issuer_id, json_key]
  end

  if payload.match?(/\A[A-Za-z0-9+\/=\r\n]+\z/)
    compact_payload = payload.gsub(/\s+/, "")
    padded_payload = compact_payload + ("=" * ((4 - compact_payload.length % 4) % 4))
    decoded = if compact_payload.include?("-") || compact_payload.include?("_")
                Base64.urlsafe_decode64(padded_payload)
              else
                Base64.strict_decode64(padded_payload)
              end
    parsed_decoded = parse_asc_payload(decoded, key_id, issuer_id) if decoded != payload
    return parsed_decoded if parsed_decoded

    # Some CI secrets are stored as the base64 body/DER bytes of the .p8 file
    # without the PEM envelope. Re-wrap those bytes as PKCS8 PEM for Fastlane.
    if decoded.bytesize > 100
      pem_body = Base64.strict_encode64(decoded).scan(/.{1,64}/).join("\n")
      return [key_id, issuer_id, "-----BEGIN PRIVATE KEY-----\n#{pem_body}\n-----END PRIVATE KEY-----"]
    end
  end

  nil
rescue StandardError
  nil
end

def load_asc_api_key
  # Support all common ASC_KEY_CONTENT formats used in CI: raw .p8 PEM,
  # base64-encoded .p8 PEM, raw JSON, or base64-encoded JSON.
  key_path = File.expand_path("~/.appstoreconnect/api_key.json")
  key_id = ENV["ASC_KEY_ID"]
  issuer_id = ENV["ASC_ISSUER_ID"]

  candidates = []
  candidates << ENV["ASC_KEY_CONTENT"]
  candidates << File.read(key_path) if File.exist?(key_path)

  parsed = candidates.filter_map { |candidate| parse_asc_payload(candidate, key_id, issuer_id) }.find { |_, _, key| key && key.match?(/-----BEGIN (EC )?PRIVATE KEY-----/) }
  UI.user_error!("ASC_KEY_CONTENT must contain a valid App Store Connect .p8 key, either raw or base64-encoded") unless parsed

  app_store_connect_api_key(
    key_id:      parsed[0],
    issuer_id:   parsed[1],
    key_content: parsed[2],
    in_house:    false
  )
end

def bump_build
  # Increment build number using the current timestamp so it's always unique
  build_number = Time.now.strftime("%Y%m%d%H%M")
  increment_build_number(build_number: build_number)
  UI.success "Build number set to #{build_number}"
end

# ─────────────────────────────────────────────────────────────────────────────
platform :ios do

  # ---------------------------------------------------------------------------
  # before_all: runs before every lane
  # ---------------------------------------------------------------------------
  before_all do
    # Ensure Xcode command line tools are available
    xcode_select("/Applications/Xcode.app") if File.exist?("/Applications/Xcode.app")

    # Generate .xcodeproj from project.yml (xcodegen)
    # Installed via Homebrew in CI; safe to run every time - it's idempotent
    sh("which xcodegen || brew install xcodegen")
    sh("cd .. && xcodegen generate --spec project.yml")
  end

  # ---------------------------------------------------------------------------
  # certificates: sync signing certs/profiles via Match
  # Call this directly if you need to regenerate certs: fastlane certificates
  # ---------------------------------------------------------------------------
  lane :certificates do |options|
    api_key = load_asc_api_key
    readonly = options.key?(:readonly) ? options[:readonly] : true
    readonly = readonly.to_s.downcase == "true" unless [true, false].include?(readonly)

    match(
      type:                    options[:type] || "appstore",
      app_identifier:          APP_IDENTIFIER,
      team_id:                 TEAM_ID,
      git_url:                 ENV["MATCH_GIT_URL"],      # private repo URL
      git_basic_authorization: ENV["MATCH_GIT_AUTH"],     # base64(user:pat)
      readonly:                readonly,
      api_key:                 api_key
    )
  end

  # ---------------------------------------------------------------------------
  # beta: build + upload to TestFlight
  # Triggered automatically on every push to main
  # ---------------------------------------------------------------------------
  lane :beta do
    api_key = load_asc_api_key

    bump_build

    certificates(type: "appstore", readonly: true)

    gym(
      scheme:                  SCHEME,
      project:                 XCODEPROJ,
      configuration:           "Release",
      export_method:           "app-store",
      export_options: {
        provisioningProfiles: {
          APP_IDENTIFIER => "match AppStore #{APP_IDENTIFIER}"
        }
      },
      output_directory:        "./build",
      output_name:             "LLMChat.ipa",
      clean:                   true,
      silent:                  false
    )

    pilot(
      api_key:                  api_key,
      ipa:                      "./build/LLMChat.ipa",
      skip_waiting_for_build_processing: true,
      changelog:                changelog_from_git_commits(
                                  merge_commit_filtering: "exclude_merges"
                                )
    )

    UI.success "✅ Uploaded to TestFlight!"
  end

  # ---------------------------------------------------------------------------
  # release: submit for App Store review
  # Triggered manually or on a version tag push (v*)
  # ---------------------------------------------------------------------------
  lane :release do
    api_key = load_asc_api_key

    # Bump marketing version from git tag if running in CI
    if ENV["GITHUB_REF_TYPE"] == "tag"
      version = ENV["GITHUB_REF_NAME"].delete_prefix("v")
      increment_version_number(version_number: version)
    end

    bump_build

    certificates(type: "appstore", readonly: true)

    gym(
      scheme:                  SCHEME,
      project:                 XCODEPROJ,
      configuration:           "Release",
      export_method:           "app-store",
      export_options: {
        provisioningProfiles: {
          APP_IDENTIFIER => "match AppStore #{APP_IDENTIFIER}"
        }
      },
      output_directory:        "./build",
      output_name:             "LLMChat.ipa",
      clean:                   true
    )

    deliver(
      api_key:                  api_key,
      ipa:                      "./build/LLMChat.ipa",
      skip_screenshots:         true,
      skip_metadata:            false,
      submit_for_review:        true,
      force:                    true,
      automatic_release:        false,    # manual release after Apple approves
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )

    UI.success "🚀 Submitted for App Store review!"
  end

  # ---------------------------------------------------------------------------
  # register_device: add a test device UDID to the portal
  # Usage: fastlane register_device name:"Mat's iPhone" udid:"abc123..."
  # ---------------------------------------------------------------------------
  lane :register_device do |options|
    api_key = load_asc_api_key
    register_devices(
      devices: { options[:name] => options[:udid] },
      api_key: api_key,
      team_id: TEAM_ID
    )
    # Re-generate provisioning profiles to include the new device
    match(
      type:                    "adhoc",
      force_for_new_devices:   true,
      app_identifier:          APP_IDENTIFIER,
      team_id:                 TEAM_ID,
      git_url:                 ENV["MATCH_GIT_URL"],
      git_basic_authorization: ENV["MATCH_GIT_AUTH"],
      api_key:                 api_key
    )
  end

  # ---------------------------------------------------------------------------
  # Error handling
  # ---------------------------------------------------------------------------
  error do |lane, exception|
    UI.error "❌ Lane #{lane} failed: #{exception.message}"
    # Add Slack/Discord notification here if you want alerts:
    # slack(message: "Build failed: #{exception.message}", success: false, ...)
  end

end
